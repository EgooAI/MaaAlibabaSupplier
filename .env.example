# Alibaba Supplier data directory (where stores IMServiceDir/MessageSDK/{ali_id}@icbu/database/im.sqlite)
ALIBABA_DATA_DIR=foobar/AlibabaSupplierData

# MaaPiCli runtime.
MAAFW_EXECUTABLE=./gui/MaaPiCli.exe
MAAFW_WORKDIR=./gui
MAAFW_ARGS=

# MITM proxy (Yak): auto-started by main program via yak_mitm.yak.
MITM_PROXY_HOST=127.0.0.1
MITM_PROXY_PORT=8084

# MITM v4 receiver: Python app listens here for Yak/Yakit forwarded traffic.
MITM_RECEIVER_HOST=127.0.0.1
MITM_RECEIVER_PORT=8085

# Web UI server
MAA_WEB_HOST=127.0.0.1
MAA_WEB_PORT=8787

# SQLite path for MITM pools
MAA_POOLS_DB_PATH=data/pools.db

# SMTP server hostname
EMAIL_SMTP_SERVER=smtpdm.aliyun.com
# SMTP server port
EMAIL_SMTP_PORT=80
# SMTP auth username
EMAIL_SMTP_USERNAME=your-name@notify.example.com
# SMTP auth password
EMAIL_SMTP_PASSWORD=replace-with-your-password
# Default sender address
EMAIL_FROM_ADDRESS=your-name@notify.example.com
# Default sender display name
EMAIL_FROM_NAME=MaaAlibabaSupplier

# OpenAI API Settings
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=replace-with-your-openai-api-key
OPENAI_MODEL=gpt-4o
