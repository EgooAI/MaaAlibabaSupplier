                ]
            }
        },
        "next": [
            "ChatHistory_SelectMove1"
        ]
    },
    "__ChatHistory_SelectMoveCandidate1": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": [
                    "Chat/按钮_买家特征.png"
                ],
                "roi": [
                    296,
                    463,
                    550,
                    167
                ]
            }
        }
    },
    "__ChatHistory_SelectMoveCandidate2": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": [
                    "Chat/按钮_商机汇总.png"
                ],
                "roi": [
                    296,
