                    550,
                    167
                ]
            }
        }
    },
    "ChatHistory_SelectMove1": {
        "desc": "滑动选取光标",
        "recognition": {
            "type": "Or",
            "param": {
                "any_of": [
                    "__ChatHistory_SelectMoveCandidate1",
                    "__ChatHistory_SelectMoveCandidate2"
                ]
            }
        },
        "action": {
            "type": "Swipe",
            "param": {
                "begin": "ChatHistory_SelectStart",
                "begin_offset": [
                    30,
                    45,
                    -20,
                    -20
                ],
                "end_offset": [
                    20,
                    -15,
                    -20,
                    -20
                ],
                "only_hover": true
            }
        },
        "next": [
            "ChatHistory_ClickEnd"
        ]
    },
    "ChatHistory_ClickEnd": {
