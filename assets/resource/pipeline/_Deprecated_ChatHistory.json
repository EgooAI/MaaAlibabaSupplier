{ // 已弃用，现在采用 yak 网络拦截的方案来获取聊天记录
    "ChatHistory_Enter": {
        "desc": "聊天记录获取任务的入口点",
        "next": [
            "ChatHistory_FocusChat"
        ]
    },
    "ChatHistory_FocusChat": {
        "desc": "点击聊天视图以确保其获得焦点",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": [
                    "Chat/按钮_音视频通话.png"
                ],
                "roi": [
                    719,
                    14,
                    121,
                    124
                ]
            }
        },
        "action": {
            "type": "Click",
            "param": {
                "target_offset": [
                    15,
                    45,
                    -20,
                    -20
                ]
            }
        },
        "next": [
            "ChatHistory_TypeHome"
        ]
    },
    "ChatHistory_TypeHome": {
        "desc": "在聊天中键入Home按键以滚动到顶部",
        "action": {
            "type": "ClickKey",
            "param": {
                "key": 36
            }
        },
        "next": [
            "ChatHistory_SelectStart"
        ]
    },
    "ChatHistory_SelectStart": {
        "desc": "开始选取聊天消息的文本",
