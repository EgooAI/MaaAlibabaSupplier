{
    // 本文件主要定义了通用 UI 的行为和显示内容
    // 可参考文档和示例添加更多您需要的功能
    // 文档：https://maafw.xyz/docs/3.3-ProjectInterfaceV2
    // 示例：https://github.com/MaaXYZ/MaaFramework/blob/main/sample/interface.json
    "interface_version": 2,
    "name": "MaaAlibabaSupplier",
    "description": "阿里卖家自动化（基于 MaaFW）",
    "contact": "EgooAI",
    "license": "MIT",
    "welcome": "欢迎您使用 MaaAlibabaSupplier!",
    // 填写项目地址和版本号可实现自动更新功能
    // "github": "https://github.com/MaaXYZ/MaaPracticeBoilerplate",
    // "version": "1.0.0",
    // Mirror酱为第三方分发服务，新项目默认关闭
    // 若有需要请联系 Mirror酱 开通，直接自行开启是无法使用的
    // "mirrorchyan_rid": "MaaXXX",
    // "mirrorchyan_multiplatform": true,
    "controller": [
        {
            "name": "Windows",
            "type": "Win32",
            "display_long_side": 1280,
            "win32": {
                "class_regex": "Qt",
                "window_regex": "接待中心",
                "screencap": "Background", // 截图方式
                "mouse": "Seize", // 鼠标控制方式
                "keyboard": "SendMessage" // 键盘控制方式
            }
        }
    ],
    "resource": [
        {
            "name": "Default",
            "path": [
                "./resource"
            ]
        }
    ],
    "agent": {
        "child_exec": "python",
        "child_args": [
            "./../agent/main.py"
        ]
    },
    "task": [
        {
            "name": "普通任务",
            "entry": "MyTask1"
        }
    ],
    "option": {
        "任务选项1": {
            "type": "select",
            "cases": [
                {
                    "name": "文本1",
                    "pipeline_override": {}
                },
                {
                    "name": "文本2",
                    "pipeline_override": {}
                }
            ]
        }
    }
}